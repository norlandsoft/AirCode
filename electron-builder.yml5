appId: com.norlandsoft.aircode
productName: AirCode
directories:
  buildResources: resources
  output: release
files:
  - out
  - "!out/renderer/**/*.map"
mac:
  icon: resources/icon.icns
  target:
    - dmg
    - zip
  category: public.app-category.developer-tools
  artifactName: ${name}-${version}-${arch}.${ext}
