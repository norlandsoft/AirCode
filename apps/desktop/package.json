{
  "name": "@aircode/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:host && tauri dev",
    "dev:ui": "vite",
    "build": "npm run build:host && vite build && tauri build",
    "build:host": "tsc -p tsconfig.host.json",
    "build:ui": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.host.json --noEmit",
    "tauri": "tauri"
  },
  "dependencies": {
    "@aircode/runtime": "0.1.0",
    "@aircode/shared": "0.1.0",
    "@tauri-apps/api": "2.11.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "22.18.6",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.3",
    "typescript": "5.9.3",
    "vite": "7.1.6"
  }
}
